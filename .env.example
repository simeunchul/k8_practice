# ── Kafka ────────────────────────────────────────────────
# 호스트에서 직접 producer/consumer 실행 시 (docker-compose EXTERNAL 리스너)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC=econ.indicators

# ── ECOS (한국은행 경제통계시스템) ────────────────────────
# https://ecos.bok.or.kr/api 에서 무료 발급. 없으면 producer --mock 으로 대체.
ECOS_API_KEY=

# ── KOSIS (국가통계포털) ──────────────────────────────────
KOSIS_API_KEY=

# ── 수집 설정 ─────────────────────────────────────────────
POLL_INTERVAL_SECONDS=10
